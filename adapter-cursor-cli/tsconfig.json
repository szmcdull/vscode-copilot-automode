{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": false,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../shared/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "../shared/src/**/*.test.ts",
    "../shared/src/**/*.live.test.ts"
  ]
}
